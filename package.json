{
  "name": "personalized-learning-multi-agent-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "desktop": "electron .",
    "desktop:pack": "electron-builder --dir",
    "desktop:build": "electron-builder --win nsis",
    "portable:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-portable.ps1",
    "backend": "node backend/server.js",
    "frontend": "node frontend/server.js",
    "new-frontend": "node new_frontend/server.js",
    "seed:course": "node scripts/seed-course-sources.js",
    "db:migrate": "node scripts/migrate.js",
    "db:status": "node scripts/migrate.js --status",
    "test": "node --test"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "iconv-lite": "^0.7.3",
    "marked": "^18.0.6",
    "mysql2": "^3.22.6"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "cn.softwarecup.personalizedlearning",
    "productName": "个性化学习系统",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": ".cache/python-3.13.14-embed-amd64",
        "to": "python"
      }
    ],
    "files": [
      "backend/**/*",
      "database/**/*",
      "electron/**/*",
      "frontend/**/*",
      "scripts/migrate.js",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "PersonalizedLearning-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "个性化学习系统"
    }
  }
}
