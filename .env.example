# Copy this file to .env and fill in your real API key.
# OpenAI official:
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=sk-your-api-key

# Optional request timeout in milliseconds.
OPENAI_TIMEOUT_MS=180000

# SQLite is the default and needs no configuration.
# SQLITE_FILE=D:/path/to/learning.sqlite3

# Optional MySQL persistence. Uncomment either MYSQL_URL or all host fields.
# MYSQL_URL=mysql://user:password@127.0.0.1:3306/softwarecup
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=softwarecup
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=softwarecup
# MYSQL_CONNECTION_LIMIT=6
WORKSPACE_STATE_KEY=default

# Browser session and CORS.
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SESSION_COOKIE_NAME=softwarecup_session
SESSION_TTL_DAYS=30
SESSION_COOKIE_SECURE=false

# Server-side code judge runtime. The backend auto-builds the judge image.
CONTAINER_CLI=docker
# JUDGE_DOCKER_HOST=tcp://127.0.0.1:2375
JUDGE_IMAGE=softwarecup-code-judge:latest
JUDGE_TIMEOUT_MS=10000
JUDGE_AUTO_BOOTSTRAP=true

# Optional local/embedded Python interpreter. The portable ZIP sets this itself.
# PYTHON_EXECUTABLE=C:/path/to/python.exe
