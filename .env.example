# Copy this file to .env and fill in your real API key.
# OpenAI official:
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=sk-your-api-key

# Optional request timeout in milliseconds.
OPENAI_TIMEOUT_MS=180000

# Optional MySQL persistence. Use either MYSQL_URL or host/user/database fields.
# MYSQL_URL=mysql://user:password@127.0.0.1:3306/softwarecup
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=softwarecup
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=softwarecup
WORKSPACE_STATE_KEY=default

# Server-side code judge runtime. The backend auto-builds the judge image.
CONTAINER_CLI=docker
# JUDGE_DOCKER_HOST=tcp://127.0.0.1:2375
JUDGE_IMAGE=softwarecup-python-judge:latest
JUDGE_TIMEOUT_MS=10000
JUDGE_AUTO_BOOTSTRAP=true
